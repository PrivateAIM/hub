{
    "include-component-in-tag": false,
    "release-type": "node",
    "bump-minor-pre-major": true,
    "bump-patch-for-minor-pre-major": true,
    "packages": {
        ".": { "component": "root", "extra-files": ["CITATION.cff"] },
        "apps/client-ui": {"component": "client-ui" },
        "packages/client-vue": {"component": "client-vue" },
        "packages/client-vue-theme": {"component": "client-vue-theme" },
        "packages/core-http-kit": {"component": "core-http-kit" },
        "packages/core-kit": {"component": "core-kit" },
        "packages/core-realtime-kit": {"component": "core-realtime-kit" },
        "packages/kit": {"component": "kit" },
        "packages/messenger-kit": {"component": "messenger-kit" },
        "packages/messenger-http-kit": {"component": "messenger-http-kit" },
        "apps/server-core": {"component": "server-core" },
        "apps/server-core-worker": {"component": "server-core-worker" },
        "packages/server-core-worker-kit": {"component": "server-core-worker-kit" },
        "packages/server-db-kit": {"component": "server-db-kit" },
        "packages/server-http-kit": {"component": "server-http-kit" },
        "packages/server-kit": {"component": "server-kit" },
        "apps/server-messenger": {"component": "server-messenger" },
        "packages/server-realtime-kit": {"component": "server-realtime-kit" },
        "packages/server-test-kit": {"component": "server-test-kit" },
        "apps/server-storage": {"component": "server-storage"},
        "packages/server-storage-kit": {"component": "server-storage-kit" },
        "packages/storage-kit": {"component": "storage-kit"},
        "apps/server-telemetry": {"component": "server-telemetry"},
        "packages/server-telemetry-kit": {"component": "server-telemetry-kit"},
        "packages/telemetry-kit": {"component": "telemetry-kit"},
        "docs": {"component": "docs"}
    },
    "plugins": [
        {
            "type": "node-workspace",
            "updatePeerDependencies": true,
            "updateAllPackages": true
        },
        {
            "type": "linked-versions",
            "groupName": "monorepo",
            "components": [
                "root",
                "client-ui",
                "client-vue",
                "client-vue-theme",
                "core-http-kit",
                "core-kit",
                "core-realtime-kit",
                "kit",
                "messenger-kit",
                "messenger-http-kit",
                "server-core",
                "server-core-worker",
                "server-core-worker-kit",
                "server-db-kit",
                "server-http-kit",
                "server-kit",
                "server-messenger",
                "server-realtime-kit",
                "server-test-kit",
                "server-storage",
                "server-storage-kit",
                "storage-kit",
                "server-telemetry",
                "server-telemetry-kit",
                "telemetry-kit",
                "docs"
            ]
        }
    ],
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}
