        "@privateaim/messenger-kit": "^0.11.6",
        "@privateaim/server-db-kit": "^0.11.6",
        "@privateaim/server-http-kit": "^0.12.0",
        "@privateaim/server-kit": "^0.12.0",
        "@privateaim/server-realtime-kit": "^0.12.0",
        "@privateaim/server-telemetry-kit": "^0.11.6",
