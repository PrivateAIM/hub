{
    "name": "@privateaim/server-messenger",
    "type": "module",
    "version": "0.8.34",
    "private": true,
    "module": "./dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "license": "Apache-2.0",
    "description": "This package contains the realtime application which connects the API with socket based clients.",
    "dependencies": {
        "@authup/kit": "^1.0.0-beta.35",
        "@authup/core-kit": "^1.0.0-beta.35",
        "@ebec/http": "^4.0.0",
        "@privateaim/kit": "^0.8.34",
        "@privateaim/messenger-kit": "^0.7.35",
        "@privateaim/server-kit": "^0.8.34",
        "@privateaim/server-telemetry-kit": "^0.8.34",
        "@privateaim/server-http-kit": "^0.8.34",
        "@privateaim/server-realtime-kit": "^0.8.34",
        "@privateaim/telemetry-kit": "^0.8.34",
        "citty": "^0.2.1",
        "dotenv": "^17.4.1",
        "eldin": "^1.1.0",
        "envix": "^1.3.0",
        "hapic": "^2.8.2",
        "redis-extension": "^2.0.4",
        "orkos": "^1.1.1",
        "reflect-metadata": "^0.2.2",
        "routup": "^4.1.0",
        "socket.io": "^4.8.2"
    },
    "scripts": {
        "cli": "node dist/cli/index.mjs",
        "cli-dev": "ts-node src/cli/index.ts",
        "build:js": "tsdown",
        "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
        "build": "rimraf dist/ && npm run build:js && npm run build:types"
    }
}
