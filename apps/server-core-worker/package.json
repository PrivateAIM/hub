{
    "name": "@privateaim/server-core-worker",
    "type": "module",
    "version": "0.12.4",
    "private": true,
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "author": {
        "name": "Peter Placzek",
        "email": "tadashi@animesu.net",
        "url": "https://tada5hi.net"
    },
    "license": "Apache-2.0",
    "description": "This project contains the core worker service.",
    "scripts": {
        "lint": "eslint --ext .ts src/",
        "lint:fix": "npm run lint -- --fix",
        "start": "node dist/index.mjs",
        "build:js": "rimraf ./dist && tsdown",
        "build:types": "tsc --noEmit -p tsconfig.build.json",
        "build": "npm run build:js && npm run build:types",
        "test": "cross-env NODE_ENV=test vitest run --config test/vitest.config.ts",
        "test:coverage": "cross-env NODE_ENV=test vitest run --config test/vitest.config.ts --coverage"
    },
    "dependencies": {
        "@authup/core-http-kit": "^1.0.0-beta.56",
        "@hapic/harbor": "^3.0.1",
        "@privateaim/core-http-kit": "^0.12.4",
        "@privateaim/core-kit": "^0.12.4",
        "@privateaim/kit": "^0.12.4",
        "@privateaim/server-core-worker-kit": "^0.12.3",
        "@privateaim/server-kit": "^0.12.4",
        "@privateaim/server-telemetry-kit": "^0.12.3",
        "@privateaim/storage-kit": "^0.12.4",
        "@privateaim/telemetry-kit": "^0.12.4",
        "@validup/zod": "^0.3.3",
        "docken": "^2.0.2",
        "dockerode": "^5.0.1",
        "dotenv": "^17.4.1",
        "eldin": "^1.2.0",
        "envix": "^1.3.0",
        "hapic": "^3.0.1",
        "orkos": "^1.1.1",
        "redis-extension": "^2.0.4",
        "routup": "^6.0.0",
        "tar": "^7.5.22",
        "tar-fs": "^3.1.3",
        "tar-stream": "^3.2.0",
        "uuid": "^14.0.1",
        "validup": "^0.5.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/dockerode": "^4.0.1",
        "@types/tar-fs": "^2.0.4",
        "@types/tar-stream": "^3.1.4",
        "@types/uuid": "^11.0.0",
        "ts-node": "^10.9.2",
        "vitest": "^4.1.10"
    },
    "publishConfig": {
        "access": "public"
    }
}
