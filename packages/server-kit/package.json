{
    "name": "@privateaim/server-kit",
    "type": "module",
    "version": "0.12.3",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist"
    ],
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "author": {
        "name": "Peter Placzek",
