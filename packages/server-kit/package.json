        "triple-beam": "^1.4.1",
        "winston": "^3.19.0",
        "winston-transport": "^4.9.0"
    },
    "devDependencies": {
        "@authup/access": "^1.0.0-beta.54",
        "@authup/core-http-kit": "^1.0.0-beta.54",
        "@authup/core-kit": "^1.0.0-beta.54",
