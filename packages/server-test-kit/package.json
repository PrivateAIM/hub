{
    "name": "@privateaim/server-test-kit",
    "type": "module",
    "version": "0.12.3",
    "license": "Apache-2.0",
    "description": "Shared test fakes and helpers for PrivateAIM server packages.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./setup": {
            "types": "./dist/setup.d.mts",
            "import": "./dist/setup.mjs"
        }
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "devDependencies": {
        "@authup/access": "^1.0.0-beta.56",
        "@authup/core-kit": "^1.0.0-beta.56",
        "@privateaim/errors": "^0.8.42",
        "@privateaim/server-kit": "^0.12.3",
        "testcontainers": "^12.0.4",
        "vitest": "^4.1.10"
    },
    "peerDependencies": {
        "@authup/access": "^1.0.0-beta.56",
        "@authup/core-kit": "^1.0.0-beta.56",
        "@privateaim/errors": "^0.8.42",
        "@privateaim/server-kit": "^0.12.3"
    },
    "scripts": {
        "build:js": "rimraf ./dist && tsdown",
        "build:types": "tsc --noEmit -p tsconfig.build.json",
        "build": "npm run build:js && npm run build:types"
    },
    "publishConfig": {
        "access": "public"
    }
}
